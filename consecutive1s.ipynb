   "source": [
    "def is_consecutive(n):\n",
    "    return ((n & (n<<1)) != 0)\n",
    "\n",
    "def main():\n",
    "    n = int(input())\n",
    "    print(is_consecutive(n))\n",
    "\n",
    "if __name__ == '__main__':\n",
    "    main()"
   ]
