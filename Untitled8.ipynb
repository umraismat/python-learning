   "source": [
    "def factorial(n):\n",
    "    res = 1\n",
    "    for i in range(1,6):\n",
    "        res *+ i \n",
    "    return res\n",
    "\n",
    "def main():\n",
    "    n = int(input())\n",
    "    print(factorial(n))\n",
    "\n",
    "if __name__ == '__main__':\n",
    "    main()\n",
    "\n",
