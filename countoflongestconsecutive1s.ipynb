   "source": [
    "def max_consecutive(n):\n",
    "    \n",
    "    count = 0\n",
    "    while n>0:\n",
    "        n = n & (n<<1) \n",
    "        count = count +1\n",
    "    return count\n",
    "\n",
    "def main():\n",
    "    n = int(input())\n",
    "    print(max_consecutive(n))\n",
    "\n",
    "if __name__ =='__main__':\n",
    "    main()\n",
    "\n",
